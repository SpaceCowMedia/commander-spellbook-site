{
  "name": "spellbook-client-next",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3000",
    "build": "next build",
    "start": "next start",
    "lint": "eslint . && stylelint '**/*.{css,scss,vue}' && prettier --check .",
    "tsc": "tsc",
    "cy:run": "cypress run",
    "cy:open": "cypress open",
    "cy:debug": "concurrently --kill-others \"yarn dev\" \"yarn cy:open\"",
    "cy:dev": "yarn build && concurrently --kill-others \"yarn start\" \"yarn cy:open\"",
    "prettier": "prettier --write .",
    "test:integration": "yarn start & wait-on http://localhost:3000 && yarn run cy:run",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{js,ts,vue}": "eslint",
    "*.{css,scss,vue}": [
      "stylelint",
      "prettier --check"
    ]
  },
  "dependencies": {
    "@fortawesome/fontawesome-svg-core": "^7.2.0",
    "@fortawesome/free-solid-svg-icons": "^7.2.0",
    "@fortawesome/react-fontawesome": "^3.3.0",
    "@space-cow-media/spellbook-client": "^5.5.0",
    "canvas": "^3.2.3",
    "cookies-next": "^6.1.1",
    "debounce": "^3.0.0",
    "markdown-to-jsx": "^9.7.15",
    "next": "^16.2.7",
    "nextjs-progressbar": "^0.0.16",
    "pluralize": "^8.0.0",
    "react": "^19.2.7",
    "react-confirm-alert": "^3.0.6",
    "react-cookie": "^8.1.2",
    "react-dom": "^19.2.7",
    "react-markdown": "^10.1.0",
    "react-select": "^5.10.2",
    "react-swipeable": "^7.0.2",
    "react-tooltip": "^6.0.3",
    "remark-gfm": "^4.0.1",
    "remark-rehype": "^11.1.2",
    "scryfall-client": "^0.24.8",
    "sharp": "^0.34.5",
    "use-debounce": "^10.1.1"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^20.3.0",
    "@eslint/compat": "^2.0.5",
    "@eslint/js": "^10.0.1",
    "@next/eslint-plugin-next": "^16.2.10",
    "@scryfall/api-types": "^1.0.0-alpha.4",
    "@tailwindcss/postcss": "^4.3.2",
    "@types/gtag.js": "^0.0.20",
    "@types/node": "^25.9.3",
    "@types/pluralize": "^0.0.33",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/uuid": "^11.0.0",
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "@typescript-eslint/parser": "^8.60.1",
    "concurrently": "^9.2.1",
    "cypress": "^15.18.1",
    "eslint": "^10.4.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-check-file": "^3.3.1",
    "eslint-plugin-cypress": "^6.4.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "husky": "^9.1.7",
    "jiti": "^2.6.1",
    "lint-staged": "^17.0.8",
    "postcss": "^8.5.18",
    "prettier": "^3.9.5",
    "sass": "^1.101.0",
    "stylelint": "^17.13.0",
    "stylelint-config-prettier-scss": "^1.0.0",
    "stylelint-config-standard": "^40.0.0",
    "stylelint-config-standard-scss": "^17.0.0",
    "stylelint-prettier": "^5.0.3",
    "stylelint-scss": "^7.2.0",
    "tailwindcss": "^4.3.2",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.0",
    "wait-on": "^9.0.10"
  }
}
